generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model HostAccount {
  id         String     @id
  name       String
  activities Activity[]
}

model Activity {
  id                String            @id @default(cuid())
  title             String
  accessCode        String            @unique
  createdAt         DateTime          @default(now())
  deletedAt         DateTime?
  state             ActivityState     @default(DRAFT)
  questionCharLimit Int               @default(240)
  ownerId           String
  owner             HostAccount       @relation(fields: [ownerId], references: [id])
  audienceSessions  AudienceSession[]
  audienceQuestions AudienceQuestion[]
  polls             Poll[]
}

model AudienceSession {
  id                String             @id @default(cuid())
  activityId        String
  displayName       String?
  createdAt         DateTime           @default(now())
  activity          Activity           @relation(fields: [activityId], references: [id])
  audienceQuestions AudienceQuestion[]
  questionLikes     QuestionLike[]
  pollVotes         PollVote[]
}

model AudienceQuestion {
  id                String          @id @default(cuid())
  activityId        String
  audienceSessionId String
  text              String
  createdAt         DateTime        @default(now())
  isPinned          Boolean         @default(false)
  isAnswered        Boolean         @default(false)
  isHidden          Boolean         @default(false)
  activity          Activity        @relation(fields: [activityId], references: [id])
  audienceSession   AudienceSession @relation(fields: [audienceSessionId], references: [id])
  questionLikes     QuestionLike[]

  @@index([activityId, isHidden, isAnswered, createdAt])
}

enum ActivityState {
  DRAFT
  LIVE
  ENDED
}

model QuestionLike {
  id                 String           @id @default(cuid())
  audienceQuestionId String
  audienceSessionId  String
  createdAt          DateTime         @default(now())
  audienceQuestion   AudienceQuestion @relation(fields: [audienceQuestionId], references: [id])
  audienceSession    AudienceSession  @relation(fields: [audienceSessionId], references: [id])

  @@unique([audienceQuestionId, audienceSessionId])
  @@index([audienceQuestionId])
}

model Poll {
  id         String       @id @default(cuid())
  activityId String
  prompt     String
  sortOrder  Float        @default(0)
  isClosed   Boolean      @default(false)
  createdAt  DateTime     @default(now())
  activity   Activity     @relation(fields: [activityId], references: [id])
  options    PollOption[]
  votes      PollVote[]

  @@index([activityId, sortOrder])
}

model PollOption {
  id        String      @id @default(cuid())
  pollId    String
  text      String
  sortOrder Int         @default(0)
  poll      Poll        @relation(fields: [pollId], references: [id])
  votes     PollVote[]

  @@index([pollId, sortOrder])
}

model PollVote {
  id                String          @id @default(cuid())
  pollId            String
  pollOptionId      String
  audienceSessionId String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @default(now())
  poll              Poll            @relation(fields: [pollId], references: [id])
  pollOption        PollOption      @relation(fields: [pollOptionId], references: [id])
  audienceSession   AudienceSession @relation(fields: [audienceSessionId], references: [id])

  @@unique([pollId, audienceSessionId])
  @@index([pollId])
  @@index([pollId, pollOptionId])
}
